@model IEnumerable<BankingManagementSystem.Models.BankTransaction>

@{
    ViewData["Title"] = "Transactions";
}

<h1>Transactions</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Deposit / Withdrawal</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Account Number</th>
            <th>Customer</th>
            <th>Type</th>
            <th>Amount</th>
            <th>Date</th>
            <th>Description</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Account?.AccountNumber</td>
                <td>@item.Account?.Customer?.FirstName @item.Account?.Customer?.LastName</td>
                <td>@item.TransactionType</td>
                <td>@item.Amount.ToString("C")</td>
                <td>@item.TransactionDate.ToShortDateString()</td>
                <td>@item.Description</td>
            </tr>
        }
    </tbody>
</table>